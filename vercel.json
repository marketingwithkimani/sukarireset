{
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.9.0" },
    "index.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    {
      "src": "/assets/Sukari_Reset_Companion\\.apk",
      "headers": {
        "Content-Type": "application/vnd.android.package-archive",
        "Content-Disposition": "attachment; filename=\"Sukari_Reset_Companion.apk\"",
        "Cache-Control": "no-cache"
      },
      "dest": "/assets/Sukari_Reset_Companion.apk"
    },
    {
      "src": "/(assets|js|data)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/api/(.*)\\.php",
      "dest": "/api/$1.php"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}

