{
  "functions": {
    "api/*.php": { "runtime": "vercel-php@0.9.0" },
    "views/*.php": { "runtime": "vercel-php@0.9.0" },
    "index.php": { "runtime": "vercel-php@0.9.0" }
  },
  "routes": [
    {
      "src": "/(assets|js|data)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/views/(.*)",
      "dest": "/views/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}
